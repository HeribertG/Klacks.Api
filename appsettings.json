{
  "Version": "1.0.1-deploy-test",
  "ConnectionStrings": {
    "DefaultConnection": "User ID=admin;Password=admin;Host=postgres;Port=5432;Database=Klacks;Pooling=true;"
  },
  "OpenRouteService": {
    "ApiKey": "",
    "BaseUrl": "https://api.openrouteservice.org/v2"
  },
  "JwtSettings": {
    "Secret": "REPLACE_VIA_USER_SECRETS_OR_ENV",
    "ValidAudience": "https://localhost:44371",
    "ValidIssuer": "https://localhost:44371"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CurrentPaths": {
    "Documents": "Documents",
    "Images": "Images",
    "Temp": "Temp"
  },
  "AllowedHosts": "*",
  "PasswordReset": {
    "BaseUrl": "https://localhost:5001"
  },
  "Cors": {
    "Host": "https://localhost:44371",
    "Home": "http://localhost:4200"
  },
  "Database": {
    "InitializeOnStartup": true
  },
  "Fake": {
    "WithFake": "True",
    "ClientNumber": "5000",
    "MaxBreaksPerClientPerYear": "70"
  },
  "LanguagePlugins": {
    "Directory": "Plugins/Languages",
    "MarketplaceUrl": "http://157.180.42.127:7003",
    "MarketplaceApiKey": "REPLACE_VIA_USER_SECRETS_OR_ENV"
  },
  "BackgroundServices": {
    "ScheduleTimeline": true,
    "PeriodHours": true,
    "MemoryCleanup": true,
    "Heartbeat": true,
    "Embedding": true,
    "SkillGapSuggestion": true,
    "EmailPolling": true
  },
  "Languages": {
    "Supported": ["de", "en", "fr", "it"],
    "FallbackOrder": ["de", "fr", "it", "en"],
