        "SpeechLocale": "en-US"
      },
      "fr": {
        "Name": "French",
        "DisplayName": "Français",
        "SpeechLocale": "fr-FR"
      },
      "it": {
        "Name": "Italian",
        "DisplayName": "Italiano",
        "SpeechLocale": "it-IT"
      }
    }
  }
